<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hospital.controller.AddPatientController"
      spacing="10">

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="110" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <Label text="Patient ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtId" GridPane.rowIndex="0" GridPane.columnIndex="1" editable="false"/>

        <Label text="Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtName" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="e.g. Arjun Sharma"/>

        <Label text="Age:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtAge" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="e.g. 30"/>

        <Label text="Ailment:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtAilment" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="e.g. Fever"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Clear" onAction="#handleClear"/>
        <Button text="Add Patient" onAction="#handleAddPatient"/>
    </HBox>
</VBox>
