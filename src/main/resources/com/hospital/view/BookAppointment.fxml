<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hospital.controller.BookAppointmentController"
      spacing="10">

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="110" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <Label text="Appointment ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtApptId" GridPane.rowIndex="0" GridPane.columnIndex="1" editable="false"/>

        <Label text="Patient:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cmbPatient" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Select patient"/>

        <Label text="Doctor:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cmbDoctor" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Select doctor"/>

        <Label text="Date:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpDate" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Clear" onAction="#handleClear"/>
        <Button text="Book Appointment" onAction="#handleBookAppointment"/>
    </HBox>
</VBox>
