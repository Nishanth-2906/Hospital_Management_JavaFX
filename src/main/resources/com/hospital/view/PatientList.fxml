<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hospital.controller.PatientListController"
      spacing="0">

    <!-- Page header -->
    <VBox styleClass="page-header" spacing="4">
        <Label text="📋  Patient Records" styleClass="page-title"/>
        <Label text="Browse, search and manage all registered patients."
               styleClass="page-subtitle"/>
    </VBox>

    <VBox styleClass="form-card" spacing="12" VBox.vgrow="ALWAYS">

        <!-- Toolbar row -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="txtSearch" promptText="🔍  Search by name, ID or ailment..."
                       styleClass="form-field" prefWidth="320"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblCount" styleClass="count-label"/>
            <Button text="🔄  Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
            <Button text="✏  Edit Selected" onAction="#handleEdit" styleClass="btn-primary"/>
            <Button text="🗑  Delete Selected" onAction="#handleDelete" styleClass="btn-danger"/>
        </HBox>

        <!-- TableView -->
        <TableView fx:id="tablePatients" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="colId"      text="Patient ID"  prefWidth="100"/>
                <TableColumn fx:id="colName"    text="Name"        prefWidth="200"/>
                <TableColumn fx:id="colAge"     text="Age"         prefWidth="70"/>
                <TableColumn fx:id="colAilment" text="Ailment"     prefWidth="220"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

    </VBox>
</VBox>
