<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hospital.controller.DoctorListController"
      spacing="0">

    <VBox spacing="4">
        <Label text="Doctor Directory" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <Label text="Browse, search and manage all registered doctors."/>
    </VBox>

    <VBox spacing="12" VBox.vgrow="ALWAYS">

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="txtSearch" promptText="Search by name, ID or specialization..." prefWidth="340"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblCount"/>
            <Button text="Refresh" onAction="#handleRefresh"/>
            <Button text="Edit Selected" onAction="#handleEdit"/>
            <Button text="Delete Selected" onAction="#handleDelete"/>
        </HBox>

        <!-- TableView -->
        <TableView fx:id="tableDoctors" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="colId"   text="Doctor ID"      prefWidth="100"/>
                <TableColumn fx:id="colName" text="Name"           prefWidth="200"/>
                <TableColumn fx:id="colAge"  text="Age"            prefWidth="70"/>
                <TableColumn fx:id="colSpec" text="Specialization" prefWidth="200"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

    </VBox>
</VBox>
