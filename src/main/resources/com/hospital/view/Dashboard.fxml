<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hospital.controller.DashboardController"
            prefWidth="1000" prefHeight="680">

    <top>
        <HBox spacing="10">
            <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
            <Label text="Hospital Management System" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#refreshStats"/>
            <Button text="Admin Mode" disable="true"/>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">
            <Tab text="Patient List">
                <fx:include source="PatientList.fxml"/>
            </Tab>
            <Tab text="Doctor List">
                <fx:include source="DoctorList.fxml"/>
            </Tab>
            <Tab text="Appointment List">
                <fx:include source="AppointmentList.fxml"/>
            </Tab>
            <Tab text="Add Patient">
                <fx:include source="AddPatient.fxml"/>
            </Tab>
            <Tab text="Add Doctor">
                <fx:include source="AddDoctor.fxml"/>
            </Tab>
            <Tab text="Book Appointment">
                <fx:include source="BookAppointment.fxml"/>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
