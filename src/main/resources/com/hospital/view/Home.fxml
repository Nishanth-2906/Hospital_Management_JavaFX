<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hospital.controller.HomeController"
      spacing="24" alignment="CENTER"
      style="-fx-padding: 40;">

    <!-- Welcome hero -->
    <Label text="🏥" style="-fx-font-size: 64px;"/>
    <Label text="Welcome to Hospital Management System"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
    <Label text="Manage patients, doctors, and appointments from a single dashboard."
           style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" wrapText="true"
           maxWidth="500" alignment="CENTER"/>

    <Separator maxWidth="400"/>

    <!-- Feature cards -->
    <HBox spacing="20" alignment="CENTER">
        <VBox styleClass="info-card" spacing="8" alignment="CENTER" prefWidth="160">
            <Label text="👤" style="-fx-font-size: 32px;"/>
            <Label text="Patients" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Label text="Add and manage patient records" wrapText="true" alignment="CENTER"
                   style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
        </VBox>
        <VBox styleClass="info-card" spacing="8" alignment="CENTER" prefWidth="160">
            <Label text="🩺" style="-fx-font-size: 32px;"/>
            <Label text="Doctors" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Label text="Manage doctor profiles &amp; specializations" wrapText="true" alignment="CENTER"
                   style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
        </VBox>
        <VBox styleClass="info-card" spacing="8" alignment="CENTER" prefWidth="160">
            <Label text="📅" style="-fx-font-size: 32px;"/>
            <Label text="Appointments" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Label text="Book and track patient appointments" wrapText="true" alignment="CENTER"
                   style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
        </VBox>
    </HBox>

    <Separator maxWidth="400"/>

    <!-- OOP concepts reminder -->
    <VBox spacing="6" alignment="CENTER" style="-fx-padding: 16; -fx-background-color: #eff6ff;
          -fx-background-radius: 8; -fx-border-color: #bfdbfe; -fx-border-radius: 8;">
        <Label text="OOP Concepts Demonstrated" style="-fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
        <HBox spacing="30" alignment="CENTER">
            <Label text="🔷 Abstraction" style="-fx-text-fill: #1e3a5f; -fx-font-size: 12px;"/>
            <Label text="🔶 Inheritance" style="-fx-text-fill: #1e3a5f; -fx-font-size: 12px;"/>
            <Label text="🔹 Encapsulation" style="-fx-text-fill: #1e3a5f; -fx-font-size: 12px;"/>
            <Label text="🔸 Polymorphism" style="-fx-text-fill: #1e3a5f; -fx-font-size: 12px;"/>
        </HBox>
    </VBox>

    <Label text="Use the sidebar menu to navigate →"
           style="-fx-font-size: 12px; -fx-text-fill: #9ca3af; -fx-font-style: italic;"/>
</VBox>
