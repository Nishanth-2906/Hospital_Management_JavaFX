<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hospital.controller.AddDoctorController"
      spacing="0" maxWidth="520">

    <!-- Page header -->
    <VBox styleClass="page-header" spacing="4">
        <Label text="➕  Add New Doctor" styleClass="page-title"/>
        <Label text="Register a new doctor profile into the system."
               styleClass="page-subtitle"/>
    </VBox>

    <!-- Form card -->
    <VBox styleClass="form-card" spacing="18">

        <!-- Auto ID (read-only) -->
        <VBox spacing="4">
            <Label text="Doctor ID (Auto-generated)" styleClass="field-label"/>
            <TextField fx:id="txtId" styleClass="form-field" editable="false"
                       style="-fx-background-color: #f3f4f6;"/>
        </VBox>

        <!-- Name -->
        <VBox spacing="4">
            <Label text="Full Name *" styleClass="field-label"/>
            <TextField fx:id="txtName" promptText="e.g. Ananya Singh"
                       styleClass="form-field"/>
        </VBox>

        <!-- Age -->
        <VBox spacing="4">
            <Label text="Age *" styleClass="field-label"/>
            <TextField fx:id="txtAge" promptText="e.g. 40"
                       styleClass="form-field"/>
        </VBox>

        <!-- Specialization -->
        <VBox spacing="4">
            <Label text="Specialization *" styleClass="field-label"/>
            <ComboBox fx:id="cmbSpecialization" maxWidth="Infinity"
                      styleClass="form-field"/>
        </VBox>

        <!-- Buttons -->
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="🗑  Clear" onAction="#handleClear"
                    styleClass="btn-secondary"/>
            <Button text="✔  Add Doctor" onAction="#handleAddDoctor"
                    styleClass="btn-primary"/>
        </HBox>

    </VBox>
</VBox>
